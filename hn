def get_cache_key(text: str) -> str:
    return hashlib.md5(text.encode("utf-8")).hexdigest()

def is_error_text(text: str) -> bool:
    """Whether a string is an error message that should not be cached."""
    return bool(text) and text.strip().startswith("[错误]")

def call_llm(prompt: str, cfg: dict) -> str:
    """Call LLM API and return response text"""
    try:
        r = requests.post(
            cfg["url"],
            headers={
                "Content-Type": "application/json",
                "Authorization": f"Bearer {cfg['key']}",
            },
            json={
                "model": cfg["model"],
                "messages": [{"role": "user", "content": prompt}],
                "temperature": 0.3,
                "max_tokens": 4096,
            },
            timeout=30,
        )
        r.raise_for_status()
        data = r.json()
        return data["choices"][0]["message"]["content"]
    except requests.exceptions.Timeout:
        return "[错误] 请求超时，请检查网络连接"
    except requests.exceptions.ConnectionError:
        return "[错误] 无法连接到 API 服务器"
    except KeyError:
        return "[错误] API 返回格式异常"
    except Exception as e:
        return f"[错误] {str(e)}"


