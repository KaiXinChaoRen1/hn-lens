    def draw_translation_popup(self):
        """Draw translation overlay on top of current view"""
        h, w = self.stdscr.getmaxyx()
        box_h = h - 4
        box_w = w - 4
        start_y = 2
        start_x = 2
        content_w = max(1, box_w - 6)
        visible_rows = max(1, box_h - 4)

        all_lines = self.build_translation_popup_lines(content_w)
        total = len(all_lines)
        max_scroll = max(0, total - visible_rows)
        if self.trans_scroll > max_scroll:
            self.trans_scroll = max_scroll
        if self.trans_scroll < 0:
            self.trans_scroll = 0

        try:
            # Clear popup area
            for y in range(box_h):
                self.stdscr.addnstr(start_y + y, start_x, " " * box_w, box_w)

            # Border
            self.stdscr.attron(curses.color_pair(8))
            self.stdscr.addnstr(start_y, start_x, "┌" + "─" * (box_w - 2) + "┐", box_w)
            for y in range(1, box_h - 1):
                self.stdscr.addnstr(start_y + y, start_x, "│", 1)
                self.stdscr.addnstr(start_y + y, start_x + box_w - 1, "│", 1)
            self.stdscr.addnstr(start_y + box_h - 1, start_x, "└" + "─" * (box_w - 2) + "┘", box_w)
            self.stdscr.attroff(curses.color_pair(8))

            scroll_bar_x = start_x + box_w - 2
            if total > visible_rows:
                bar_h = max(1, int(visible_rows * visible_rows / total))
                max_top = visible_rows - bar_h
                bar_top = int(self.trans_scroll / max_scroll * max_top) if max_scroll > 0 else 0
            else:
                bar_h = 0
                bar_top = 0

            for i in range(visible_rows):
                idx = self.trans_scroll + i
                ry = start_y + 1 + i
                if idx >= total or ry >= start_y + box_h - 2:
                    break

                line_type, text = all_lines[idx]

                if line_type == "sep":
                    self.stdscr.attron(curses.color_pair(8))
                    self.stdscr.addnstr(ry, start_x, "├" + "─" * (box_w - 2) + "┤", box_w)
                    self.stdscr.attroff(curses.color_pair(8))
                elif line_type in ("label", "status"):
                    self.stdscr.attron(curses.A_BOLD)
                    self.stdscr.addnstr(ry, start_x + 2, text, content_w)
                    self.stdscr.attroff(curses.A_BOLD)
                else:
                    self.stdscr.addnstr(ry, start_x + 2, text, content_w)

                if bar_h > 0:
                    self.stdscr.attron(curses.color_pair(8))
                    self.stdscr.addnstr(ry, scroll_bar_x, "│", 1)
                    if bar_top <= i < bar_top + bar_h:
                        self.stdscr.addnstr(ry, scroll_bar_x, "█", 1)
                    self.stdscr.attroff(curses.color_pair(8))

            if self.translating:
                self.trans_frame += 1

            # Footer
            self.stdscr.attron(curses.color_pair(8))
            footer = "Esc: 关闭  j/k: 滚动  PgUp/PgDn: 翻页  g/G: 顶部/底部"
            self.stdscr.addnstr(start_y + box_h - 2, start_x + 2, footer, box_w - 4)
            self.stdscr.attroff(curses.color_pair(8))

            self.stdscr.refresh()
        except curses.error:
            pass

    def build_translation_popup_lines(self, content_w: int):
        """Build wrapped lines for the translation popup."""
        lines = [("label", "Original")]
        for line in wrap_by_width(self.trans_source, content_w):
            lines.append(("source", line))

        lines.append(("sep", ""))
        model_name = self.cfg.get("model", "unknown")
        lines.append(("label", f"Translation ({model_name})"))

        if self.translating:
            spinner = ["|", "/", "-", "\\"]
            frame = spinner[self.trans_frame % len(spinner)]
            lines.append(("status", f"[ {frame} ] 正在请求大模型，请稍候..."))
        elif self.trans_result:
            for raw_line in self.trans_result.split("\n"):
                wrapped = wrap_by_width(raw_line, content_w)
                if wrapped:
                    for line in wrapped:
                        lines.append(("result", line))
                else:
                    lines.append(("result", ""))
        else:
            lines.append(("status", "暂无翻译结果"))

        return lines

