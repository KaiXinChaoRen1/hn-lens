def safe_curs_set(visibility):
    """Best-effort cursor visibility change for terminals that support it."""
    try:
        curses.curs_set(visibility)
    except curses.error:
        pass

def get_display_width(text):
    """Calculate display width of a string (CJK chars = 2, others = 1)"""
    width = 0
    for ch in text:
        cp = ord(ch)
        if cp > 0x1100 and (
            cp <= 0x115f or  # Hangul Jamo
            0x2e80 <= cp <= 0x9fff or  # CJK
            0xac00 <= cp <= 0xd7af or  # Hangul Syllables
            0xf900 <= cp <= 0xfaff or  # CJK Compatibility Ideographs
            0xff01 <= cp <= 0xff60 or  # Fullwidth ASCII
            0xffe0 <= cp <= 0xffe6 or  # Fullwidth symbols
            0x20000 <= cp <= 0x2a6df or  # CJK Extension B
            0x2a700 <= cp <= 0x2ebef  # CJK Extension C-F
        ):
            width += 2
        else:
            width += 1
    return width

def wrap_by_width(text, max_width):
    """Wrap text by display width instead of character count"""
    if not text:
        return [""]
    lines = text.split("\n")
    result = []
    for line in lines:
        if not line:
            result.append("")
            continue
        current = ""
        current_width = 0
        for ch in line:
            ch_width = 2 if ord(ch) > 0x1100 and (
                ord(ch) <= 0x115f or 0x2e80 <= ord(ch) <= 0x9fff or
                0xac00 <= ord(ch) <= 0xd7af or 0xf900 <= ord(ch) <= 0xfaff or
                0xff01 <= ord(ch) <= 0xff60 or 0xffe0 <= ord(ch) <= 0xffe6 or
                0x20000 <= ord(ch) <= 0x2a6df or 0x2a700 <= ord(ch) <= 0x2ebef
            ) else 1
            if current_width + ch_width > max_width and current:
                result.append(current)
                current = ch
                current_width = ch_width
            else:
                current += ch
                current_width += ch_width
        if current:
            result.append(current)
    return result if result else [""]

