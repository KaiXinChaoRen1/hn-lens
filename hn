def safe_curs_set(visibility):
    """Best-effort cursor visibility change for terminals that support it."""
    try:
        curses.curs_set(visibility)
    except curses.error:
        pass

def get_display_width(text):
    """Calculate display width of a string (CJK chars = 2, others = 1)"""
    width = 0
    for ch in text:
        cp = ord(ch)
        if cp > 0x1100 and (
            cp <= 0x115f or  # Hangul Jamo
            0x2e80 <= cp <= 0x9fff or  # CJK
            0xac00 <= cp <= 0xd7af or  # Hangul Syllables
            0xf900 <= cp <= 0xfaff or  # CJK Compatibility Ideographs
            0xff01 <= cp <= 0xff60 or  # Fullwidth ASCII
            0xffe0 <= cp <= 0xffe6 or  # Fullwidth symbols
            0x20000 <= cp <= 0x2a6df or  # CJK Extension B
            0x2a700 <= cp <= 0x2ebef  # CJK Extension C-F
        ):
            width += 2
        else:
            width += 1
    return width

def split_wrap_tokens(line):
    """Split a line into whitespace, ASCII-word, and single-char tokens."""
    tokens = []
    i = 0
    while i < len(line):
        ch = line[i]
        if ch.isspace():
            j = i + 1
            while j < len(line) and line[j].isspace():
                j += 1
            tokens.append(line[i:j])
            i = j
        elif ord(ch) < 128 and not ch.isspace():
            j = i + 1
            while j < len(line) and ord(line[j]) < 128 and not line[j].isspace():
                j += 1
            tokens.append(line[i:j])
            i = j
        else:
            tokens.append(ch)
            i += 1
    return tokens

def wrap_long_token(token, max_width):
    """Hard-wrap a single token that is wider than the available width."""
    parts = []
    current = ""
    current_width = 0
    for ch in token:
        ch_width = get_display_width(ch)
        if current and current_width + ch_width > max_width:
            parts.append(current)
            current = ch
            current_width = ch_width
        else:
            current += ch
            current_width += ch_width
    if current:
        parts.append(current)
    return parts if parts else [""]

def wrap_by_width(text, max_width):
    """Wrap text by display width instead of character count"""
    if not text:
        return [""]
    if max_width <= 1:
        return [text]
    lines = text.split("\n")
    result = []
    for line in lines:
        if not line:
            result.append("")
            continue
        current = ""
        current_width = 0
        for token in split_wrap_tokens(line):
            token_width = get_display_width(token)

            if current and current_width + token_width > max_width:
                if token.isspace():
                    result.append(current.rstrip())
                    current = ""
                    current_width = 0
                    continue

                result.append(current.rstrip())
                current = ""
                current_width = 0

            if token_width > max_width and not token.isspace():
                wrapped_parts = wrap_long_token(token, max_width)
                if current:
                    result.append(current.rstrip())
                    current = ""
                    current_width = 0
                result.extend(wrapped_parts[:-1])
                current = wrapped_parts[-1]
                current_width = get_display_width(current)
            elif not current and token.isspace():
                continue
            else:
                current += token
                current_width += token_width
        if current:
            result.append(current.rstrip())
    return result if result else [""]

