@dataclass
class Story:
    """Hacker News story data"""
    title: str
    author: str
    points: int
    num_comments: int
    url: Optional[str]
    object_id: str
    created_at: int
    story_type: str = "story"

    @property
    def hn_url(self) -> str:
        """Get the Hacker News discussion URL"""
        return f"https://news.ycombinator.com/item?id={self.object_id}"

    @classmethod
    def from_api(cls, data: Dict[str, Any]) -> "Story":
        """Create Story from Algolia API response"""
        url = data.get("url", "")
        return cls(
            title=data.get("title", ""),
            author=data.get("author", ""),
            points=data.get("points", 0),
            num_comments=data.get("num_comments", 0),
            url=url if url else None,
            object_id=data.get("objectID", ""),
            created_at=data.get("created_at_i", int(time.time())),
            story_type=data.get("_tags", ["story"])[0] if data.get("_tags") else "story",
        )


@dataclass
class Comment:
    """Hacker News comment data"""
    author: str
    text: str
    time: int
    depth: int


INITIAL_STORY_PAGE_SIZE = 20
STORY_LOAD_MORE_SIZE = 10
INITIAL_COMMENT_BATCH_SIZE = 20
COMMENT_LOAD_MORE_SIZE = 10

TAG_MAP = {
    "top": "front_page",
    "ask": "ask_hn",
}

def fetch_stories(feed_type, offset=0, count=INITIAL_STORY_PAGE_SIZE):
    """Fetch a batch of stories from Algolia API."""
    tag = TAG_MAP.get(feed_type, "front_page")
    page = offset // count if count > 0 else 0
    url = f"{ALGOLIA_API}/search?tags={tag}&hitsPerPage={count}&page={page}"
    try:
        r = requests.get(url, timeout=15)
        r.raise_for_status()
        data = r.json()
        stories = [Story.from_api(hit) for hit in data.get("hits", [])]
        current_page = data.get("page", page)
        total_pages = data.get("nbPages", current_page + 1)
        has_more = current_page + 1 < total_pages and bool(stories)
        return stories, has_more, None
    except Exception as e:
        return [], False, str(e)

def fetch_comments(story_id):
    """Fetch a story with its comments via Algolia items API"""
    url = f"{ALGOLIA_API}/items/{story_id}"
    try:
        r = requests.get(url, timeout=15)
        r.raise_for_status()
        return r.json()
    except Exception:
        return None

def flatten_comments(item, depth=0, result=None) -> List[Comment]:
    """Recursively flatten comment tree into a list"""
    if result is None:
        result = []
    if not item or not isinstance(item, dict):
        return result
    if item.get("type") == "comment" and item.get("text"):
        result.append(Comment(
            author=item.get("author", ""),
            text=item.get("text", ""),
            time=item.get("created_at_i", 0),
            depth=depth,
        ))
    children = item.get("children", [])
    for child in children:
        flatten_comments(child, depth + 1, result)
    return result

def time_ago(ts):
    diff = int(time.time()) - ts
    if diff < 60:
        return f"{diff}s ago"
    elif diff < 3600:
        return f"{diff//60}m ago"
    elif diff < 86400:
        return f"{diff//3600}h ago"
    elif diff < 604800:
        return f"{diff//86400}d ago"
    else:
        return f"{diff//604800}w ago"

def open_url(url):
    if not url:
        return
    try:
        subprocess.Popen(["xdg-open", url], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except:
        try:
            subprocess.Popen(["open", url], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        except:
            pass

def strip_html(text):
    if not text:
        return ""
    clean = re.sub(r'<[^>]+>', '', text)
    clean = clean.replace('&amp;', '&').replace('&lt;', '<').replace('&gt;', '>').replace('&quot;', '"').replace('&#x27;', "'").replace('&nbsp;', ' ')
    clean = re.sub(r'\n{3,}', '\n\n', clean)
    return clean.strip()

def normalize_whitespace(text):
    """Collapse repeated inline whitespace while preserving paragraph breaks."""
    if not text:
        return ""
    return re.sub(r'\s+', ' ', text).strip()

def is_structured_article_line(line):
    """Whether a rendered article line already has intentional structure."""
    if not line:
        return False
    return (
        line.startswith('#')
        or line.startswith('> ')
        or line.startswith('• ')
        or line.startswith('    ')
        or bool(re.match(r'^\d+\.\s', line))
        or ' | ' in line
    )

def fetch_article_text(url):
    """Fetch article content and convert HTML to structured plain text"""
    if not url:
        return None
    try:
        r = requests.get(url, timeout=15, headers={"User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36"})
        r.raise_for_status()
        html = r.text

        try:
            from readability import Document
            from bs4 import BeautifulSoup, Comment, NavigableString
        except Exception:
            try:
                from bs4 import BeautifulSoup, Comment, NavigableString
            except Exception:
                # Last-resort fallback: return stripped raw HTML text.
                clean = strip_html(html)
                return clean[:10000] if clean else None

        noise_keywords = (
            'ad', 'ads', 'advert', 'banner', 'cookie', 'consent', 'footer',
            'menu', 'nav', 'navbar', 'sidebar', 'share', 'social', 'promo',
            'related', 'recommend', 'trending', 'newsletter', 'subscribe',
            'signup', 'sign-up', 'signin', 'sign-in', 'outbrain', 'taboola',
            'breadcrumb', 'comment', 'responses', 'reply'
        )
        positive_keywords = (
            'article', 'content', 'entry', 'main', 'post', 'story', 'body',
            'copy', 'text', 'page'
        )

        def parse_soup(fragment):
            return BeautifulSoup(fragment, 'html.parser')

        def candidate_text_len(node):
            return len(normalize_whitespace(node.get_text(" ", strip=True)))

        def choose_root_soup():
            candidates = []
            try:
                doc = Document(html)
                summary_html = doc.summary()
                if summary_html:
                    candidates.append(("summary", parse_soup(summary_html)))
            except Exception:
                pass

            full_soup = parse_soup(html)
            body = full_soup.body or full_soup
            candidates.append(("body", parse_soup(str(body))))

            best = None
            best_score = -1
            for source, candidate in candidates:
                text_len = candidate_text_len(candidate)
                if source == "summary" and text_len >= 180:
                    return candidate

                score = text_len
                if source == "summary":
                    score += 500

                if score > best_score:
                    best = candidate
                    best_score = score
            return best or parse_soup(html)

        def attr_blob(node):
            attrs = []
            for key in ('id', 'class', 'role', 'aria-label', 'data-testid', 'data-component'):
                value = node.get(key)
                if isinstance(value, list):
                    attrs.extend(value)
                elif value:
                    attrs.append(str(value))
            return " ".join(attrs).lower()

        def is_noise_node(node):
            if not getattr(node, 'name', None):
                return False
            if node.name in ('script', 'style', 'nav', 'footer', 'header', 'aside', 'form', 'button', 'noscript'):
                return True
            if node.name in ('img', 'svg', 'canvas', 'iframe', 'video', 'audio', 'figure', 'figcaption'):
                return True

            attrs = attr_blob(node)
            if attrs:
                has_noise = any(keyword in attrs for keyword in noise_keywords)
                has_positive = any(keyword in attrs for keyword in positive_keywords)
                if has_noise and not has_positive:
                    return True

            text = normalize_whitespace(node.get_text(" ", strip=True))
            text_len = len(text)
            if text_len == 0:
                return False

            links = node.find_all('a')
            if not links:
                return False

            link_text_len = sum(len(normalize_whitespace(link.get_text(" ", strip=True))) for link in links)
            link_density = link_text_len / max(text_len, 1)
            if len(links) >= 6 and link_density > 0.55:
                return True
            if len(links) >= 4 and text_len < 140 and link_density > 0.45:
                return True
            return False

        def clean_soup(soup):
            for comment in soup.find_all(string=lambda text: isinstance(text, Comment)):
                comment.extract()

            for node in list(soup.find_all(True)):
                if is_noise_node(node):
                    node.decompose()

            for node in soup.find_all(True):
                if node.name in ('div', 'section', 'article', 'main'):
                    if not normalize_whitespace(node.get_text(" ", strip=True)):
                        node.decompose()
            return soup

        def append_block(lines, text, prefix=""):
            if not text:
                return
            text_lines = [normalize_whitespace(line) for line in text.splitlines()]
            text_lines = [line for line in text_lines if line]
            if not text_lines:
                return
            lines.append("")
            for line in text_lines:
                lines.append(f"{prefix}{line}" if prefix else line)
            lines.append("")

        def render_node(node, lines):
            if isinstance(node, NavigableString):
                return
            if not getattr(node, 'name', None):
                return

            tag = node.name
            if tag in ('article', 'main', 'section', 'div', 'body'):
                for child in node.children:
                    render_node(child, lines)
                return

            if tag in ('h1', 'h2', 'h3', 'h4', 'h5', 'h6'):
                level = min(3, int(tag[1]))
                text = normalize_whitespace(node.get_text(" ", strip=True))
                append_block(lines, f"{'#' * level} {text}" if text else "")
                return

            if tag == 'p':
                append_block(lines, normalize_whitespace(node.get_text(" ", strip=True)))
                return

            if tag == 'blockquote':
                text = node.get_text("\n", strip=True)
                append_block(lines, text, prefix="> ")
                return

            if tag == 'pre':
                text = node.get_text("\n", strip=True)
                if text:
                    lines.append("")
                    for raw in text.splitlines():
                        lines.append(f"    {raw.rstrip()}")
                    lines.append("")
                return

            if tag == 'ul':
                items = []
                for li in node.find_all('li', recursive=False):
                    item = normalize_whitespace(li.get_text(" ", strip=True))
                    if item:
                        items.append(f"• {item}")
                append_block(lines, "\n".join(items))
                return

            if tag == 'ol':
                items = []
                for idx, li in enumerate(node.find_all('li', recursive=False), 1):
                    item = normalize_whitespace(li.get_text(" ", strip=True))
                    if item:
                        items.append(f"{idx}. {item}")
                append_block(lines, "\n".join(items))
                return

            if tag == 'table':
                rows = []
                for tr in node.find_all('tr'):
                    cells = [normalize_whitespace(cell.get_text(" ", strip=True)) for cell in tr.find_all(['th', 'td'])]
                    cells = [cell for cell in cells if cell]
                    if cells:
                        rows.append(" | ".join(cells))
                append_block(lines, "\n".join(rows))
                return

            if tag == 'hr':
                append_block(lines, "---")
                return

            if tag in ('br',):
                lines.append("")
                return

            text = normalize_whitespace(node.get_text(" ", strip=True))
            if text and not node.find(['p', 'ul', 'ol', 'pre', 'blockquote', 'table', 'h1', 'h2', 'h3', 'h4', 'h5', 'h6']):
                append_block(lines, text)
                return

            for child in node.children:
                render_node(child, lines)

        soup = clean_soup(choose_root_soup())
        root = soup.find(['article', 'main']) or soup.body or soup

        lines = []
        for child in root.children:
            render_node(child, lines)

        # Deduplicate empty lines
        out = []
        last_empty = False
        for l in lines:
            empty = not l.strip()
            if empty and last_empty:
                continue
            out.append(l)
            last_empty = empty

        rendered = '\n'.join(out).strip()
        if not rendered:
            rendered = strip_html(str(root))
        return rendered[:10000] if rendered else None
    except Exception:
        return None

class HNViewer:
    def __init__(self, stdscr):
        self.stdscr = stdscr
        self.stories: List[Story] = []
        self.selected = 0
        self.scroll = 0
        self.loading = False
        self.status = ""
        self.current_feed = "top"
        self.view_state = ViewState.LIST
        self.search_mode = False  # True when actively typing search
        self.detail_story: Optional[Story] = None
        self.all_comments: List[Comment] = []
        self.comments: List[Comment] = []
        self.comment_scroll = 0
        self.comment_selected = 0
        self.article_text: List[str] = []
        self.article_scroll = 0
        self.search_query = ""
        self.filtered_stories: List[Story] = []
        self.story_next_offset = 0
        self.story_has_more = False
        self.loading_more_stories = False
        try:
            safe_curs_set(0)
        except Exception:
            pass
        self.stdscr.timeout(10)
        self.stdscr.keypad(True)
        if curses.has_colors():
            try:
                curses.start_color()
                curses.use_default_colors()
                curses.init_pair(1, curses.COLOR_CYAN, -1)
                curses.init_pair(2, curses.COLOR_YELLOW, -1)
                curses.init_pair(3, curses.COLOR_GREEN, -1)
                curses.init_pair(4, curses.COLOR_RED, -1)
                curses.init_pair(5, curses.COLOR_WHITE, curses.COLOR_BLUE)
                curses.init_pair(6, curses.COLOR_BLACK, curses.COLOR_WHITE)
                curses.init_pair(7, curses.COLOR_MAGENTA, curses.COLOR_BLUE)
                curses.init_pair(8, curses.COLOR_WHITE, -1)
                curses.init_pair(9, curses.COLOR_WHITE, curses.COLOR_BLACK)
                curses.init_pair(10, curses.COLOR_CYAN, -1)
            except curses.error:
                pass
        self.cfg = load_config()
        self.cache = load_cache()
        self.stories_cache = load_stories_cache()
        self.pending_story_refresh = None
        self.translating = False
        self.trans_result = ""
        self.trans_source = ""
        self.trans_scroll = 0
        self.source_scroll = 0
        self.trans_frame = 0
        self.confirm_exit = False
        self.confirm_exit_time = 0

    def _comment_prefixes(self, depth: int):
        """Build softer tree prefixes for comment header/body."""
        depth = min(depth, 8)
        if depth <= 0:
            header_prefix = "• "
        else:
            header_prefix = ("  " * (depth - 1)) + "└─ "
        body_prefix = " " * get_display_width(header_prefix)
        return header_prefix, body_prefix

    def get_cached_stories(self, feed_type="top"):
        """Return recent cached stories for a feed when available."""
        cached = self.stories_cache.get(feed_type)
        if not cached:
            return None
        if time.time() - cached.get("saved_at", 0) > STORIES_CACHE_TTL:
            return None
        items = cached.get("stories", [])
        if not items:
            return None
        try:
            stories = [Story.from_api(item) for item in items]
        except Exception:
            return None
        return stories, bool(cached.get("has_more", False))

    def store_cached_stories(self, feed_type: str, stories: List[Story], has_more: bool):
        """Save the latest feed snapshot for faster next launch."""
        self.stories_cache[feed_type] = {
            "saved_at": time.time(),
            "has_more": has_more,
            "stories": [
                {
                    "title": story.title,
                    "author": story.author,
                    "points": story.points,
                    "num_comments": story.num_comments,
                    "url": story.url,
                    "objectID": story.object_id,
                    "created_at_i": story.created_at,
                    "_tags": [story.story_type],
                }
                for story in stories
            ],
        }
        save_stories_cache(self.stories_cache)

    def load_stories(self, feed_type="top", force_refresh=False):
        self.current_feed = feed_type
        cached = None
        previous_stories = list(self.stories)
        previous_has_more = self.story_has_more
        previous_next_offset = self.story_next_offset
        if force_refresh:
            if self.pending_story_refresh and self.pending_story_refresh["feed_type"] == feed_type:
                self.pending_story_refresh = None
            self.loading = True
            self.status = "Refreshing..."
            self.draw_main()
            self.stdscr.refresh()
            stories, has_more, error = fetch_stories(feed_type, offset=0, count=INITIAL_STORY_PAGE_SIZE)
            if error:
                self.stories = previous_stories
                self.story_has_more = previous_has_more
                self.story_next_offset = previous_next_offset
            else:
                self.stories = stories
                self.story_next_offset = len(stories)
                self.story_has_more = has_more
            self.loading = False
            if not error and stories:
                self.store_cached_stories(feed_type, stories, has_more)
        else:
            cached = self.get_cached_stories(feed_type)
            if cached:
                stories, has_more = cached
                self.stories = stories
                self.story_next_offset = len(stories)
                self.story_has_more = has_more
                self.loading = False
            else:
                self.loading = True
                self.status = "Loading..."
                self.draw_main()
                self.stdscr.refresh()
                stories, has_more, error = fetch_stories(feed_type, offset=0, count=INITIAL_STORY_PAGE_SIZE)
                if error:
                    self.stories = previous_stories
                    self.story_has_more = previous_has_more
                    self.story_next_offset = previous_next_offset
                else:
                    self.stories = stories
                    self.story_next_offset = len(stories)
                    self.story_has_more = has_more
                self.loading = False
                if not error and stories:
                    self.store_cached_stories(feed_type, stories, has_more)

        self.loading_more_stories = False
        self.refreshing_stories = False
        self.selected = 0
        self.scroll = 0
        self.view_state = ViewState.LIST
        self.detail_story = None
        self.all_comments = []
        self.comments = []
        self.article_text = []
        if self.search_mode:
            self.filter_stories()
            self.status = f"Search: {len(self.filtered_stories)} results | esc: exit search | j/k: nav"
        else:
            if force_refresh and 'error' in locals() and error:
                self.update_list_status("Refresh failed")
            elif (not force_refresh) and (not cached) and 'error' in locals() and error and not self.stories:
                self.status = "Failed to load stories. Press 'r' to retry."
            else:
                self.update_list_status()
        if (not force_refresh) and cached:
            self.refresh_stories_in_background(feed_type)

    def update_list_status(self, extra_msg: str = ""):
        """Refresh list status line with pagination hint."""
        base = f"Loaded {len(self.stories)} stories"
        if self.story_has_more:
            base += f" | auto-load +{STORY_LOAD_MORE_SIZE} at bottom"
        if self.refreshing_stories:
            base += " | refreshing..."
        elif self.pending_story_refresh and self.pending_story_refresh["feed_type"] == self.current_feed:
            base += " | update ready: press r"
        base += " | j/k: nav | o: detail | c: comments | a: article | T: translate | q: quit"
        if extra_msg:
            base = f"{extra_msg} | " + base
        self.status = base

    def load_more_stories(self):
        """Append the next page of stories when available."""
        if self.loading or self.loading_more_stories or not self.story_has_more or self.search_mode:
            return

        self.loading_more_stories = True
        self.status = f"Loading more stories ({self.story_next_offset + 1}-{self.story_next_offset + STORY_LOAD_MORE_SIZE})..."
        self.draw_main()
        self.stdscr.refresh()

        stories, has_more, error = fetch_stories(
            self.current_feed,
            offset=self.story_next_offset,
            count=STORY_LOAD_MORE_SIZE,
        )
        if error:
            self.update_list_status("Load more failed")
        elif stories:
            existing_ids = {story.object_id for story in self.stories}
            new_stories = [story for story in stories if story.object_id not in existing_ids]
            if new_stories:
                self.stories.extend(new_stories)
            self.story_next_offset += len(stories)
            self.story_has_more = has_more and bool(new_stories or stories)
            self.update_list_status()
        else:
            self.story_has_more = False
            self.update_list_status("No more stories available")

        self.loading_more_stories = False

    def maybe_load_more_stories(self):
        """Fetch the next page when the cursor gets near the end."""
        if self.search_mode or not self.story_has_more:
            return
        if self.selected >= max(0, len(self.stories) - 5):
            self.load_more_stories()

    def refresh_stories_in_background(self, feed_type="top"):
        """Refresh the first story batch without blocking startup."""
        if self.refreshing_stories or self.loading or self.loading_more_stories:
            return

        self.refreshing_stories = True
        self.update_list_status()

        def _refresh():
            stories, has_more, error = fetch_stories(feed_type, offset=0, count=INITIAL_STORY_PAGE_SIZE)
            if not error and stories:
                self.pending_story_refresh = {
                    "feed_type": feed_type,
                    "stories": stories,
                    "has_more": has_more,
                }
                self.store_cached_stories(feed_type, stories, has_more)
            self.refreshing_stories = False
            self.update_list_status()

        threading.Thread(target=_refresh, daemon=True).start()

    def update_comments_status(self, extra_msg: str = ""):
        """Refresh comment status line with incremental loading hint."""
        base = f"{len(self.comments)}/{len(self.all_comments)} comments"
        if len(self.comments) < len(self.all_comments):
            base += f" | auto-load +{COMMENT_LOAD_MORE_SIZE} at bottom"
        base += " | j/k: scroll | g/G: top/bottom | esc: back | q: quit"
        if extra_msg:
            base = f"{extra_msg} | " + base
        self.status = base

    def load_more_comments(self):
        """Reveal more preloaded comments for the current story."""
        if len(self.comments) >= len(self.all_comments):
            return
        next_count = min(len(self.all_comments), len(self.comments) + COMMENT_LOAD_MORE_SIZE)
        self.comments = self.all_comments[:next_count]
        self.update_comments_status()

    def maybe_load_more_comments(self):
        """Reveal more comments when the cursor gets near the end."""
        if self.comment_selected >= max(0, len(self.comments) - 3):
            self.load_more_comments()

    def load_comments(self):
        stories_list = self.filtered_stories if self.search_mode else self.stories
        if not stories_list:
            return
        s = stories_list[self.selected]
        story_id = s.object_id
        if not story_id:
            return
        self.loading = True
        self.status = f"Loading comments for: {s.title[:50]}..."
        self.draw_main()
        self.stdscr.refresh()
        item = fetch_comments(story_id)
        if item:
            self.all_comments = flatten_comments(item)
            self.comments = self.all_comments[:INITIAL_COMMENT_BATCH_SIZE]
            self.view_state = ViewState.COMMENTS
            self.comment_selected = 0
            self.comment_scroll = 0
            self.update_comments_status()
        else:
            self.all_comments = []
            self.comments = []
            self.status = "Failed to load comments. Press 'r' to retry."
        self.loading = False

    def enter_search(self):
        """Enter search input mode"""
        self.search_mode = True
        self.search_query = ""
        self.filtered_stories = self.stories[:]
        self.selected = 0
        self.scroll = 0
        safe_curs_set(1)

    def exit_search(self):
        """Exit search input mode"""
        self.search_mode = False
        self.search_query = ""
        self.filtered_stories = []
        self.selected = 0
        self.scroll = 0
        safe_curs_set(0)

    def filter_stories(self):
        """Filter stories based on search query"""
        if not self.search_query:
            self.filtered_stories = self.stories[:]
        else:
            query = self.search_query.lower()
            self.filtered_stories = [
                s for s in self.stories
                if query in s.title.lower()
                or query in s.author.lower()
            ]
        self.selected = 0
        self.scroll = 0

    def load_article(self):
        stories_list = self.filtered_stories if self.search_mode else self.stories
        if not stories_list:
            return
        s = stories_list[self.selected]
        if not s.url:
            self.status = "This post has no external URL (it's a discussion post). Press 'c' for comments."
            return
        self.loading = True
        self.status = f"Fetching article: {s.title[:50]}..."
        self.draw_main()
        self.stdscr.refresh()
        text = fetch_article_text(s.url)
        if text:
            _, w = self.stdscr.getmaxyx()
            content_w = w - 4
            raw_lines = text.split('\n')
            wrapped = []
            for line in raw_lines:
                if not line.strip():
                    wrapped.append('')
                elif is_structured_article_line(line):
                    wrapped.append(line)
                else:
                    wrapped.extend(wrap_by_width(line, content_w))
            self.article_text = wrapped

            # Aggregate paragraphs: consecutive non-empty lines form one paragraph
            self.article_paragraphs = []
            para_start = None
            for i, line in enumerate(wrapped):
                if line.strip():
                    if para_start is None:
                        para_start = i
                else:
                    if para_start is not None:
                        full_text = '\n'.join(wrapped[para_start:i])
                        self.article_paragraphs.append({
                            'start': para_start,
                            'end': i - 1,
                            'text': full_text,
                        })
                        para_start = None
            if para_start is not None:
                full_text = '\n'.join(wrapped[para_start:])
                self.article_paragraphs.append({
                    'start': para_start,
                    'end': len(wrapped) - 1,
                    'text': full_text,
                })

            self.article_scroll = 0
            self.article_selected = 0
            self.view_state = ViewState.ARTICLE
            self.status = f"Article: {s.title[:60]} | j/k: paragraph | T: translate | g/G: top/bottom | esc: back | q: quit"
        else:
            self.status = "Failed to fetch article content. Press 'c' to view comments instead."
        self.loading = False

    def draw_main(self):
        self.stdscr.erase()
        h, w = self.stdscr.getmaxyx()

        if self.search_mode:
            title = f" Search Stories - {len(self.filtered_stories)} results "
        else:
            title = f" Hacker News - {self.current_feed.upper()} "
        self.stdscr.attron(curses.color_pair(6) | curses.A_BOLD)
        self.stdscr.addnstr(0, 0, title.ljust(w), w - 1)
        self.stdscr.attroff(curses.color_pair(6) | curses.A_BOLD)

        if self.search_mode:
            menu = f" Search: {self.search_query}_ "
            self.stdscr.attron(curses.color_pair(4))
            self.stdscr.addnstr(1, 0, menu.ljust(w)[:w-1], w - 1)
            self.stdscr.attroff(curses.color_pair(4))
        else:
            menu = " [1]Top [2]Ask | [r]刷新 [/]搜索 "
            self.stdscr.attron(curses.color_pair(6))
            self.stdscr.addnstr(1, 0, menu.ljust(w), w - 1)
            self.stdscr.attroff(curses.color_pair(6))

        if self.loading:
            self.stdscr.addnstr(h // 2, w // 2 - 10, "Loading...", w - 1)
            self.stdscr.refresh()
            return

        if not self.stories:
            self.stdscr.addnstr(h // 2, w // 2 - 15, "No stories loaded. Press 'r' to retry.", w - 1)
            self.stdscr.refresh()
            return

        stories_to_show = self.filtered_stories if self.search_mode else self.stories
        visible = (h - 3) // 2  # Each story takes 2 rows
        for i in range(visible):
            idx = self.scroll + i
            if idx >= len(stories_to_show):
                break
            s = stories_to_show[idx]
            title_text = s.title
            score = s.points
            comments = s.num_comments
            ago = time_ago(s.created_at)
            domain = ""
            if s.url:
                try:
                    domain = s.url.split("//")[1].split("/")[0]
                except:
                    pass

            line_num = i * 2 + 2  # Line 2, 4, 6, ...
            meta_line = line_num + 1

            # Meta line (without author)
            meta = f"     {score}pts | {ago} | {comments} comments"
            if domain:
                meta += f" | {domain}"

            if idx == self.selected:
                title_full = f" {idx+1:>3}. {title_text}"
                if meta_line < h - 1:
                    self.stdscr.attron(curses.color_pair(7) | curses.A_BOLD)
                    self.stdscr.addnstr(line_num, 0, title_full.ljust(w - 1), w - 1)
                    self.stdscr.attroff(curses.color_pair(7) | curses.A_BOLD)
                    self.stdscr.attron(curses.color_pair(7) | curses.A_BOLD)
                    self.stdscr.addnstr(meta_line, 0, meta.ljust(w - 1), w - 1)
                    self.stdscr.attroff(curses.color_pair(7) | curses.A_BOLD)
            else:
                # Unselected: cyan number + default title
                num_str = f" {idx+1:>3}. "
                self.stdscr.attron(curses.color_pair(1))
                self.stdscr.addnstr(line_num, 0, num_str, w - 1)
                self.stdscr.attroff(curses.color_pair(1))
                self.stdscr.addnstr(line_num, len(num_str), title_text, w - len(num_str) - 1)

                # Meta line in green
                if meta_line < h - 1:
                    self.stdscr.attron(curses.color_pair(3))
                    self.stdscr.addnstr(meta_line, 0, meta[:w-1], w - 1)
                    self.stdscr.attroff(curses.color_pair(3))

        self.stdscr.attron(curses.color_pair(6))
        status_line = f" {self.status} "
        self.stdscr.addnstr(h - 1, 0, status_line.ljust(w), w - 1)
        self.stdscr.attroff(curses.color_pair(6))

        self.stdscr.refresh()

    def draw_detail(self):
        self.stdscr.erase()
        h, w = self.stdscr.getmaxyx()
        s = self.detail_story
        if not s:
            return

        title = f" {s.title} "
        self.stdscr.attron(curses.color_pair(6) | curses.A_BOLD)
        self.stdscr.addnstr(0, 0, title.ljust(w), w - 1)
        self.stdscr.attroff(curses.color_pair(6) | curses.A_BOLD)

        meta = f"  by {s.author} | {s.points} pts | {time_ago(s.created_at)} | {s.num_comments} comments"
        self.stdscr.attron(curses.color_pair(2))
        self.stdscr.addnstr(1, 0, meta, w - 1)
        self.stdscr.attroff(curses.color_pair(2))

        if s.url:
            url_line = f"  URL: {s.url}"
            self.stdscr.attron(curses.color_pair(1))
            self.stdscr.addnstr(2, 0, url_line, w - 1)
            self.stdscr.attroff(curses.color_pair(1))
            start = 3
        else:
            start = 2

        # Self-posts have text content
        text = getattr(s, 'text', None)
        if text:
            clean = strip_html(text)
            lines = textwrap.wrap(clean, width=w - 4)
            for i, line in enumerate(lines):
                if start + i < h - 2:
                    self.stdscr.addnstr(start + i, 2, line, w - 3)

        self.stdscr.attron(curses.color_pair(6))
        footer = " Press 'o' to open in browser | 'esc' to go back | 'q' to quit "
        self.stdscr.addnstr(h - 1, 0, footer.ljust(w), w - 1)
        self.stdscr.attroff(curses.color_pair(6))

        self.stdscr.refresh()

    def draw_article(self):
        self.stdscr.erase()
        h, w = self.stdscr.getmaxyx()

        if not self.article_text:
            self.stdscr.addnstr(h // 2, w // 2 - 15, "No article content available.", w - 1)
            self.stdscr.refresh()
            return

        # Title bar
        stories_list = self.filtered_stories if self.search_mode else self.stories
        story_title = stories_list[self.selected].title[:w - 4] if stories_list else "Unknown"
        title = f" Article: {story_title} "
        self.stdscr.attron(curses.color_pair(6) | curses.A_BOLD)
        self.stdscr.addnstr(0, 0, title.ljust(w), w - 1)
        self.stdscr.attroff(curses.color_pair(6) | curses.A_BOLD)

        content_w = w - 4
        visible_rows = h - 3

        # Ensure selected paragraph is visible
        if self.article_paragraphs:
            sel = self.article_paragraphs[self.article_selected]
            # Check if selected paragraph is fully or partially visible
            sel_in_view = False
            for i in range(visible_rows):
                row_idx = self.article_scroll + i
                if sel['start'] <= row_idx <= sel['end']:
                    sel_in_view = True
                    break
            if not sel_in_view:
                self.article_scroll = sel['start']

        # Render all visible lines with paragraph-level highlighting
        ry = 1
        idx = self.article_scroll
        while ry < h - 1 and idx < len(self.article_text):
            line = self.article_text[idx]
            is_selected = False
            if self.article_paragraphs:
                sel = self.article_paragraphs[self.article_selected]
                is_selected = sel['start'] <= idx <= sel['end']

            if not line.strip():
                ry += 1
                idx += 1
                continue

            if is_selected:
                # Selected paragraph: highlight with color_pair(7)
                self.stdscr.attron(curses.color_pair(7) | curses.A_BOLD)
                self.stdscr.addnstr(ry, 2, line, content_w)
                self.stdscr.attroff(curses.color_pair(7) | curses.A_BOLD)
            elif line.startswith('##'):
                self.stdscr.attron(curses.color_pair(1) | curses.A_BOLD)
                self.stdscr.addnstr(ry, 2, line, content_w)
                self.stdscr.attroff(curses.color_pair(1) | curses.A_BOLD)
            elif line.startswith('#'):
                self.stdscr.attron(curses.color_pair(1) | curses.A_BOLD | curses.A_UNDERLINE)
                self.stdscr.addnstr(ry, 2, line, content_w)
                self.stdscr.attroff(curses.color_pair(1) | curses.A_BOLD | curses.A_UNDERLINE)
            elif line.startswith('• ') or (len(line) > 2 and line[0].isdigit() and line[1] == '.'):
                self.stdscr.attron(curses.color_pair(8))
                self.stdscr.addnstr(ry, 2, line, content_w)
                self.stdscr.attroff(curses.color_pair(8))
            else:
                self.stdscr.addnstr(ry, 2, line, content_w)

            ry += 1
            idx += 1

        self.stdscr.attron(curses.color_pair(6))
        status_line = f" {self.status} "
        self.stdscr.addnstr(h - 1, 0, status_line.ljust(w), w - 1)
        self.stdscr.attroff(curses.color_pair(6))

        self.stdscr.refresh()

    def _calc_comment_rows(self, w, h, start_idx):
        """Calculate how many screen rows a comment takes, starting from start_idx.
        Returns list of (comment_index, start_row, end_row) for visible comments."""
        max_rows = h - 2  # title + status bar
        row = 1
        visible = []
        idx = start_idx
        while idx < len(self.comments) and row < max_rows:
            c = self.comments[idx]
            depth = min(c.depth, 8)
            _, body_indent = self._comment_prefixes(c.depth)

            # Separator before top-level comments
            if depth == 0 and idx > 0:
                row += 1
                if row >= max_rows:
                    break

            start_row = row
            row += 1  # header line

            text = strip_html(c.text)
            body_lines = wrap_by_width(text, max(10, w - get_display_width(body_indent) - 2))
            row += len(body_lines)

            # Gap
            if row < max_rows:
                row += 1

            visible.append((idx, start_row, row))
            idx += 1
        return visible

    def draw_comments(self):
        self.stdscr.erase()
        h, w = self.stdscr.getmaxyx()

        if not self.comments:
            self.stdscr.addnstr(h // 2, w // 2 - 10, "No comments found.", w - 1)
            self.stdscr.refresh()
            return

        # Title bar
        stories_list = self.filtered_stories if self.search_mode else self.stories
        story_title = stories_list[self.selected].title[:w - 4] if stories_list else "Unknown"
        title = f" Comments: {story_title} "
        self.stdscr.attron(curses.color_pair(6) | curses.A_BOLD)
        self.stdscr.addnstr(0, 0, title.ljust(w), w - 1)
        self.stdscr.attroff(curses.color_pair(6) | curses.A_BOLD)

        # Ensure selected comment is visible
        visible = self._calc_comment_rows(w, h, self.comment_scroll)
        if visible:
            vis_indices = [v[0] for v in visible]
            if self.comment_selected not in vis_indices:
                # Scroll to make selected comment visible
                self.comment_scroll = self.comment_selected
                visible = self._calc_comment_rows(w, h, self.comment_scroll)

        # Render visible comments
        for idx, start_row, end_row in visible:
            c = self.comments[idx]
            depth = min(c.depth, 8)
            author = c.author
            ago = time_ago(c.time)
            text = strip_html(c.text)
            indent_prefix, body_indent = self._comment_prefixes(depth)

            row = start_row

            # Separator before top-level comments
            if depth == 0 and idx > 0:
                self.stdscr.attron(curses.color_pair(8))
                self.stdscr.addnstr(row, 2, "─" * max(0, min(w - 5, 24)), w - 3)
                self.stdscr.attroff(curses.color_pair(8))
                row += 1

            is_selected = (idx == self.comment_selected)
            header = f"{indent_prefix}{author} · {ago}"

            if is_selected:
                self.stdscr.attron(curses.color_pair(5) | curses.A_BOLD)
                self.stdscr.addnstr(row, 0, header[:w-1].ljust(w - 1), w - 1)
                self.stdscr.attroff(curses.color_pair(5) | curses.A_BOLD)
            else:
                self.stdscr.attron(curses.color_pair(8))
                self.stdscr.addnstr(row, 0, indent_prefix, w - 1)
                self.stdscr.attroff(curses.color_pair(8))
                self.stdscr.attron(curses.color_pair(2) | curses.A_BOLD)
                self.stdscr.addnstr(row, len(indent_prefix), f"{author} · {ago}", w - len(indent_prefix) - 1)
                self.stdscr.attroff(curses.color_pair(2) | curses.A_BOLD)

            row += 1

            body_lines = wrap_by_width(text, max(10, w - get_display_width(body_indent) - 2))
            for bline in body_lines:
                if row >= h - 1:
                    break
                if is_selected:
                    self.stdscr.attron(curses.color_pair(5))
                    self.stdscr.addnstr(row, 0, body_indent.ljust(w - 1), w - 1)
                    self.stdscr.attroff(curses.color_pair(5))
                    self.stdscr.attron(curses.color_pair(5))
                    self.stdscr.addnstr(row, len(body_indent), bline, w - len(body_indent) - 1)
                    self.stdscr.attroff(curses.color_pair(5))
                else:
                    self.stdscr.attron(curses.color_pair(8))
                    self.stdscr.addnstr(row, 0, body_indent, w - 1)
                    self.stdscr.attroff(curses.color_pair(8))
                    self.stdscr.addnstr(row, len(body_indent), bline, w - len(body_indent) - 1)
                row += 1

        self.stdscr.attron(curses.color_pair(6))
        status_line = f" {self.status} "
        self.stdscr.addnstr(h - 1, 0, status_line.ljust(w), w - 1)
        self.stdscr.attroff(curses.color_pair(6))

        self.stdscr.refresh()

    def draw_translation_popup(self):
        """Draw translation overlay on top of current view"""
        h, w = self.stdscr.getmaxyx()
        box_h = h - 4
        box_w = w - 4
        start_y = 2
        start_x = 2
        content_w = max(1, box_w - 6)
        visible_rows = max(1, box_h - 4)

        all_lines = self.build_translation_popup_lines(content_w)
        total = len(all_lines)
        max_scroll = max(0, total - visible_rows)
        if self.trans_scroll > max_scroll:
            self.trans_scroll = max_scroll
        if self.trans_scroll < 0:
            self.trans_scroll = 0

        try:
            # Clear popup area
            for y in range(box_h):
                self.stdscr.addnstr(start_y + y, start_x, " " * box_w, box_w)

            # Border
            self.stdscr.attron(curses.color_pair(8))
            self.stdscr.addnstr(start_y, start_x, "┌" + "─" * (box_w - 2) + "┐", box_w)
            for y in range(1, box_h - 1):
                self.stdscr.addnstr(start_y + y, start_x, "│", 1)
                self.stdscr.addnstr(start_y + y, start_x + box_w - 1, "│", 1)
            self.stdscr.addnstr(start_y + box_h - 1, start_x, "└" + "─" * (box_w - 2) + "┘", box_w)
            self.stdscr.attroff(curses.color_pair(8))

            scroll_bar_x = start_x + box_w - 2
            if total > visible_rows:
                bar_h = max(1, int(visible_rows * visible_rows / total))
                max_top = visible_rows - bar_h
                bar_top = int(self.trans_scroll / max_scroll * max_top) if max_scroll > 0 else 0
            else:
                bar_h = 0
                bar_top = 0

            for i in range(visible_rows):
                idx = self.trans_scroll + i
                ry = start_y + 1 + i
                if idx >= total or ry >= start_y + box_h - 2:
                    break

                line_type, text = all_lines[idx]

                if line_type == "sep":
                    self.stdscr.attron(curses.color_pair(8))
                    self.stdscr.addnstr(ry, start_x, "├" + "─" * (box_w - 2) + "┤", box_w)
                    self.stdscr.attroff(curses.color_pair(8))
                elif line_type in ("label", "status"):
                    self.stdscr.attron(curses.A_BOLD)
                    self.stdscr.addnstr(ry, start_x + 2, text, content_w)
                    self.stdscr.attroff(curses.A_BOLD)
                else:
                    self.stdscr.addnstr(ry, start_x + 2, text, content_w)

                if bar_h > 0:
                    self.stdscr.attron(curses.color_pair(8))
                    self.stdscr.addnstr(ry, scroll_bar_x, "│", 1)
                    if bar_top <= i < bar_top + bar_h:
                        self.stdscr.addnstr(ry, scroll_bar_x, "█", 1)
                    self.stdscr.attroff(curses.color_pair(8))

            if self.translating:
                self.trans_frame += 1

            # Footer
            self.stdscr.attron(curses.color_pair(8))
            footer = "Esc: 关闭  j/k: 滚动  PgUp/PgDn: 翻页  g/G: 顶部/底部"
            self.stdscr.addnstr(start_y + box_h - 2, start_x + 2, footer, box_w - 4)
            self.stdscr.attroff(curses.color_pair(8))

            self.stdscr.refresh()
        except curses.error:
            pass

    def build_translation_popup_lines(self, content_w: int):
        """Build wrapped lines for the translation popup."""
        lines = [("label", "Original")]
        for line in wrap_by_width(self.trans_source, content_w):
            lines.append(("source", line))

        lines.append(("sep", ""))
        model_name = self.cfg.get("model", "unknown")
        lines.append(("label", f"Translation ({model_name})"))

        if self.translating:
            spinner = ["|", "/", "-", "\\"]
            frame = spinner[self.trans_frame % len(spinner)]
            lines.append(("status", f"[ {frame} ] 正在请求大模型，请稍候..."))
        elif self.trans_result:
            for raw_line in self.trans_result.split("\n"):
                wrapped = wrap_by_width(raw_line, content_w)
                if wrapped:
                    for line in wrapped:
                        lines.append(("result", line))
                else:
                    lines.append(("result", ""))
        else:
            lines.append(("status", "暂无翻译结果"))

        return lines

    def draw_confirm_exit(self):
        """Draw exit confirmation overlay"""
        h, w = self.stdscr.getmaxyx()
        msg = " 确认退出? (y/再次Ctrl+C=退出, n=取消, 5秒后自动取消) "
        y = h // 2
        x = max(0, (w - len(msg)) // 2)
        try:
            self.stdscr.attron(curses.color_pair(4) | curses.A_BOLD)
            self.stdscr.addnstr(y, x, msg, w - x - 1)
            self.stdscr.attroff(curses.color_pair(4) | curses.A_BOLD)
            self.stdscr.refresh()
        except curses.error:
            pass

    def start_translation(self, text: str):
        """Start async translation"""
        clean = text.strip()
        if not clean:
            return
        if not self.cfg.get("key") or self.cfg["key"] == "your-api-key-here":
            self.translating = False
            self.trans_result = "[错误] 请先在 ~/.hn/config.json 中配置 api_key"
            self.trans_source = clean
            self.trans_scroll = 0
            return

        cache_key = get_cache_key(clean)
        if cache_key in self.cache:
            cached_result = self.cache[cache_key]
            if is_error_text(cached_result):
                del self.cache[cache_key]
                save_cache(self.cache)
            else:
                self.translating = False
                self.trans_result = cached_result
                self.trans_source = clean
                self.trans_scroll = 0
                return

        self.translating = True
        self.trans_result = ""
        self.trans_source = clean
        self.trans_scroll = 0
        self.trans_frame = 0

        def _translate():
            result = call_llm(self.cfg["prompt_item"].format(text=clean), self.cfg)
            if not is_error_text(result):
                self.cache[get_cache_key(clean)] = result
                save_cache(self.cache)
            self.trans_result = result
            self.translating = False

        t = threading.Thread(target=_translate, daemon=True)
        t.start()

    def run(self):
        global _ctrl_c_pressed
        self.load_stories("top")
        in_translation = False
        in_confirm = False
        confirm_time = 0
        while True:
            # Highest priority: Ctrl+C signal check
            if _ctrl_c_pressed:
                _ctrl_c_pressed = False
                if in_confirm:
                    break  # Second Ctrl+C during confirm = exit
                in_confirm = True
                confirm_time = time.time()
                self.stdscr.timeout(200)
                continue

            # Check confirm timeout
            if in_confirm and time.time() - confirm_time > 5:
                in_confirm = False
                self.stdscr.timeout(-1)

            if in_confirm:
                self.stdscr.timeout(200)
            elif in_translation:
                # Only animate while the LLM request is in flight. Static popups
                # should wait for input instead of redrawing at 100 FPS.
                self.stdscr.timeout(120 if self.translating else -1)
            else:
                self.stdscr.timeout(10)

            # Draw current view
            if self.view_state == ViewState.ARTICLE:
                self.draw_article()
            elif self.view_state == ViewState.COMMENTS:
                self.draw_comments()
            elif self.view_state == ViewState.DETAIL:
                self.draw_detail()
            else:
                self.draw_main()

            if in_translation:
                self.draw_translation_popup()

            if in_confirm:
                self.draw_confirm_exit()

            key = self.stdscr.getch()

            if key == 3:  # Ctrl+C from curses input
                if in_confirm:
                    break
                in_confirm = True
                confirm_time = time.time()
                continue

            if in_confirm:
                if key == ord('y') or key == ord('Y'):
                    break
                elif key == ord('n') or key == ord('N'):
                    in_confirm = False
                continue

            if in_translation:
                if key == 27:  # ESC
                    in_translation = False
                elif key == ord('j') or key == curses.KEY_DOWN:
                    self.trans_scroll += 1
                elif key == ord('k') or key == curses.KEY_UP:
                    if self.trans_scroll > 0:
                        self.trans_scroll -= 1
                elif key == ord('g'):
                    self.trans_scroll = 0
                elif key == ord('G'):
                    popup_h = self.stdscr.getmaxyx()[0] - 4
                    visible_rows = max(1, popup_h - 4)
                    popup_w = self.stdscr.getmaxyx()[1] - 4
                    content_w = max(1, popup_w - 6)
                    total = len(self.build_translation_popup_lines(content_w))
                    self.trans_scroll = max(0, total - visible_rows)
                elif key == curses.KEY_PPAGE:
                    self.trans_scroll = max(0, self.trans_scroll - 10)
                elif key == curses.KEY_NPAGE:
                    popup_h = self.stdscr.getmaxyx()[0] - 4
                    visible_rows = max(1, popup_h - 4)
                    popup_w = self.stdscr.getmaxyx()[1] - 4
                    content_w = max(1, popup_w - 6)
                    total = len(self.build_translation_popup_lines(content_w))
                    self.trans_scroll = min(max(0, total - visible_rows), self.trans_scroll + 10)
                elif key == ord('q') or key == ord('Q'):
                    break
                continue

            if self.view_state == ViewState.ARTICLE:
                if key == 27 or key == ord('b'):
                    self.view_state = ViewState.LIST
                    self.article_text = []
                    self.article_paragraphs = []
                    self.update_list_status()
                elif key == ord('j') or key == curses.KEY_DOWN:
                    if self.article_selected < len(self.article_paragraphs) - 1:
                        self.article_selected += 1
                elif key == ord('k') or key == curses.KEY_UP:
                    if self.article_selected > 0:
                        self.article_selected -= 1
                elif key == ord('g'):
                    self.article_selected = 0
                elif key == ord('G'):
                    self.article_selected = max(0, len(self.article_paragraphs) - 1)
                elif key == ord('t') or key == ord('T'):
                    if self.article_paragraphs:
                        p = self.article_paragraphs[self.article_selected]
                        self.start_translation(p['text'])
                        in_translation = True
                elif key == ord('q') or key == ord('Q'):
                    break
            elif self.search_mode:
                stories_list = self.filtered_stories
                visible_stories = (self.stdscr.getmaxyx()[0] - 3) // 2
                if key == 27:  # ESC
                    self.exit_search()
                elif key == 10 or key == curses.KEY_ENTER:  # Enter
                    self.filter_stories()
                elif key == curses.KEY_BACKSPACE or key == 127 or key == ord('\b'):
                    if self.search_query:
                        self.search_query = self.search_query[:-1]
                        self.filter_stories()
                elif key == ord('j') or key == curses.KEY_DOWN:
                    if self.selected < len(stories_list) - 1:
                        self.selected += 1
                        if self.selected >= self.scroll + visible_stories:
                            self.scroll += 1
                elif key == ord('k') or key == curses.KEY_UP:
                    if self.selected > 0:
                        self.selected -= 1
                        if self.selected < self.scroll:
                            self.scroll -= 1
                elif key == ord('g'):
                    self.selected = 0
                    self.scroll = 0
                elif key == ord('G'):
                    self.selected = len(stories_list) - 1
                    self.scroll = max(0, self.selected - visible_stories + 1)
                elif key == curses.KEY_LEFT:
                    pass  # Ignore cursor movement in search
                elif key == curses.KEY_RIGHT:
                    pass
                elif 32 <= key <= 126:  # Printable characters
                    self.search_query += chr(key)
                    self.filter_stories()
            elif self.view_state == ViewState.COMMENTS:
                if key == 27 or key == ord('b'):
                    self.view_state = ViewState.LIST
                    self.all_comments = []
                    self.comments = []
                    self.update_list_status()
                elif key == ord('j') or key == curses.KEY_DOWN:
                    if self.comment_selected < len(self.comments) - 1:
                        self.comment_selected += 1
                        self.maybe_load_more_comments()
                elif key == ord('k') or key == curses.KEY_UP:
                    if self.comment_selected > 0:
                        self.comment_selected -= 1
                elif key == ord('g'):
                    self.comment_selected = 0
                    self.comment_scroll = 0
                elif key == ord('G'):
                    self.comment_selected = len(self.comments) - 1
                    self.maybe_load_more_comments()
                elif key == ord('t') or key == ord('T'):
                    if self.comments:
                        c = self.comments[self.comment_selected]
                        self.start_translation(strip_html(c.text))
                        in_translation = True
                elif key == ord('q') or key == ord('Q'):
                    break
            elif self.view_state == ViewState.DETAIL:
                if key == 27 or key == ord('b'):
                    self.view_state = ViewState.LIST
                    self.detail_story = None
                elif key == ord('o') or key == ord('O'):
                    if self.detail_story:
                        open_url(self.detail_story.url or self.detail_story.hn_url)
                elif key == ord('q') or key == ord('Q'):
                    break
            else:  # LIST view
                stories_list = self.filtered_stories if self.search_mode else self.stories
                visible_stories = (self.stdscr.getmaxyx()[0] - 3) // 2
                if key == ord('q') or key == ord('Q'):
                    break
                elif key == ord('j') or key == curses.KEY_DOWN:
                    if self.selected < len(stories_list) - 1:
                        self.selected += 1
                        if self.selected >= self.scroll + visible_stories:
                            self.scroll += 1
                        self.maybe_load_more_stories()
                elif key == ord('k') or key == curses.KEY_UP:
                    if self.selected > 0:
                        self.selected -= 1
                        if self.selected < self.scroll:
                            self.scroll -= 1
                elif key == ord('g'):
                    self.selected = 0
                    self.scroll = 0
                elif key == ord('G'):
                    self.selected = len(stories_list) - 1
                    self.scroll = max(0, self.selected - visible_stories + 1)
                    self.maybe_load_more_stories()
                elif key == ord('r') or key == ord('R'):
                    self.load_stories(self.current_feed, force_refresh=True)
                elif key == ord('1'):
                    self.load_stories("top")
                elif key == ord('2'):
                    self.load_stories("ask")
                elif key == ord('o') or key == ord('O') or key == ord('\n') or key == curses.KEY_RIGHT:
                    stories_list = self.filtered_stories if self.search_mode else self.stories
                    if stories_list:
                        self.detail_story = stories_list[self.selected]
                        self.view_state = ViewState.DETAIL
                elif key == ord('c') or key == ord('C'):
                    self.load_comments()
                elif key == ord('a') or key == ord('A'):
                    self.load_article()
                elif key == ord('u') or key == ord('U'):
                    stories_list = self.filtered_stories if self.search_mode else self.stories
                    if stories_list:
                        s = stories_list[self.selected]
                        open_url(s.url or s.hn_url)
                elif key == ord('/'):
                    self.enter_search()
                elif key == ord('t') or key == ord('T'):
                    stories_list = self.filtered_stories if self.search_mode else self.stories
                    if stories_list:
                        s = stories_list[self.selected]
                        self.start_translation(s.title)
                        in_translation = True

def main(stdscr):
    global _ctrl_c_pressed
    signal.signal(signal.SIGINT, _sigint_handler)
    viewer = HNViewer(stdscr)
    viewer.run()

if __name__ == "__main__":
    curses.wrapper(main)
