@dataclass
class Story:
    """Hacker News story data"""
    title: str
    author: str
    points: int
    num_comments: int
    url: Optional[str]
    object_id: str
    created_at: int
    story_type: str = "story"

    @property
    def hn_url(self) -> str:
        """Get the Hacker News discussion URL"""
        return f"https://news.ycombinator.com/item?id={self.object_id}"

    @classmethod
    def from_api(cls, data: Dict[str, Any]) -> "Story":
        """Create Story from Algolia API response"""
        url = data.get("url", "")
        return cls(
            title=data.get("title", ""),
            author=data.get("author", ""),
            points=data.get("points", 0),
            num_comments=data.get("num_comments", 0),
            url=url if url else None,
            object_id=data.get("objectID", ""),
            created_at=data.get("created_at_i", int(time.time())),
            story_type=data.get("_tags", ["story"])[0] if data.get("_tags") else "story",
        )


