def ensure_config():
    """Create config file if not exists"""
    if not os.path.exists(CONFIG_DIR):
        os.makedirs(CONFIG_DIR)
    if not os.path.exists(CONFIG_FILE):
        with open(CONFIG_FILE, "w") as f:
            json.dump(DEFAULT_CONFIG, f, indent=2, ensure_ascii=False)
    with open(CONFIG_FILE, "r") as f:
        return json.load(f)

def load_config():
    """Load config and return dict"""
    cfg = ensure_config()
    return {
        "url": cfg.get("api_url", DEFAULT_CONFIG["api_url"]),
        "key": cfg.get("api_key", ""),
        "model": cfg.get("api_model", DEFAULT_CONFIG["api_model"]),
        "prompt_word": cfg.get("prompt_word", DEFAULT_CONFIG["prompt_word"]),
        "prompt_item": cfg.get("prompt_item", DEFAULT_CONFIG["prompt_item"]),
